.vscode/*
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db

# SFTP/FTP connection profiles can contain plaintext credentials —
# never track these, regardless of the .vscode allowlist above.
sftp.json

# Python packaging artifacts
dist/
build/

# Environment / local secrets
.env
.envrc

# Editor swap files
*.swp
*.swo
*~

# Claude Code project instructions — local dev aid, not published.
CLAUDE.md

# uv-generated lockfile — not part of this project's documented workflow
# (CI and CONTRIBUTING.md both use plain `pip install -e ".[dev]"`).
# Safe to delete locally; `uv` will regenerate it if you ever use it.
uv.lock
